# Covenant — environment variable template
# Copy to .env and fill in all values. Never commit .env.

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# PostgreSQL + pgvector
DATABASE_URL=postgresql+asyncpg://covenant:changeme@localhost:5432/covenant

# OPA REST API
OPA_URL=http://localhost:8181

# JWT — use a strong random value (min 32 chars)
JWT_SECRET=change-me-before-running-in-any-real-environment
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Claude model
CLAUDE_MODEL=claude-sonnet-4-6

# Azure (used by Terraform — not needed for local Docker dev)
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# App
APP_ENV=development
LOG_LEVEL=INFO
